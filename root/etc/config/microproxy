config global 'main'
	option enabled '0'
	option tproxy_port '12345'
	option dns_port '7913'
	option fakeip_range '198.18.0.0/15'
	option route_mode 'direct_by_default'
	option dynamic_timeout '43200'
	option integrate_agh '0'

config server
	option enabled '0'
	option alias 'Sample VLESS Reality TCP'
	option type 'vless'
	option server 'example.com'
	option server_port '443'
	option uuid '00000000-0000-0000-0000-000000000000'
	option flow 'xtls-rprx-vision'
	option transport 'tcp'
	option tls '1'
	option server_name 'yahoo.com'
	option public_key 'your_public_key_here'
	option short_id 'your_short_id_here'

config observatory 'config'
	option enabled '1'
	option interval '5m'
	option probe_url 'https://www.gstatic.com/generate_204'
	option tolerance '50'

config subscription 'itdog_domains'
	option enabled '1'
	option name 'ItDog Whitelist Domains'
	option url 'https://raw.githubusercontent.com/itdoginfo/allow-domains/main/Russia/inside-raw.txt'
	option format 'text'
	option update_interval '24h'

config custom_rules 'user_rules'
	list domain 'blocked-site.com'
	list domain 'another-blocked-site.org'
	list ip '93.184.216.34'
	list ip '104.244.42.0/24'
